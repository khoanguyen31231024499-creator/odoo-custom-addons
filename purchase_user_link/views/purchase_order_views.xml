<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_purchase_order_form_po_approval_fix" model="ir.ui.view">
            <field name="name">purchase.order.form.po.approval.fix</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='locked']" position="after">
                    <field name="is_above_limit" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='state']" position="attributes">
                    <attribute name="statusbar_visible">draft,sent,to approve,purchase</attribute>
                </xpath>

                <xpath expr="//group[field[@name='date_order']]" position="after">
                    <group string="Approval" groups="purchase.group_purchase_manager">
                        <field name="amount_total_vnd" readonly="1"/>
                        <field name="approver_id" readonly="1"/>
                        <field name="approval_date" readonly="1"/>
                        <field name="rejection_reason"
                            placeholder="Enter rejection reason before rejecting the order."
                            invisible="state not in ('to approve', 'cancel')"/>

                        <button name="button_approve"
                            type="object"
                            string="Approve Order"
                            class="oe_highlight"
                            invisible="state != 'to approve'"/>

                        <button name="button_reject"
                            type="object"
                            string="Reject"
                            class="btn-secondary"
                            invisible="state != 'to approve'"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="action_purchase_orders_to_approve_po_fix" model="ir.actions.act_window">
            <field name="name">Đơn hàng chờ duyệt</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">list,form,kanban,activity</field>
            <field name="search_view_id" ref="purchase.view_purchase_order_filter"/>
            <field name="domain">[('state', '=', 'to approve')]</field>
        </record>

        <menuitem id="menu_purchase_orders_to_approve_po_fix"
            name="Đơn hàng chờ duyệt"
            parent="purchase.menu_procurement_management"
            action="action_purchase_orders_to_approve_po_fix"
            sequence="25"
            groups="purchase.group_purchase_manager"/>
    </data>
</odoo>
