<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_purchase_order_form_ptp_approval" model="ir.ui.view">
            <field name="name">purchase.order.form.ptp.approval</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='locked']" position="after">
                    <field name="is_above_limit" invisible="1"/>
                </xpath>

                <xpath expr="//button[@id='bid_confirm']" position="attributes">
                    <attribute name="invisible">state != 'sent' or is_above_limit</attribute>
                </xpath>
                <xpath expr="//button[@id='draft_confirm']" position="attributes">
                    <attribute name="invisible">state != 'draft' or is_above_limit</attribute>
                </xpath>
                <xpath expr="//button[@id='draft_confirm']" position="after">
                    <button name="button_confirm" type="object"
                        invisible="state not in ('draft', 'sent') or not is_above_limit"
                        string="Gửi yêu cầu phê duyệt"
                        context="{'validate_analytic': True}"
                        class="oe_highlight"
                        data-hotkey="q"/>
                </xpath>

                <xpath expr="//field[@name='state']" position="attributes">
                    <attribute name="statusbar_visible">draft,sent,to approve,purchase</attribute>
                </xpath>

                <xpath expr="//group[field[@name='date_order']]" position="after">
                    <group string="Approval" groups="purchase_user_link.group_purchase_manager_ptp">
                        <field name="approver_id"/>
                        <field name="approval_date" readonly="1"/>
                        <field name="rejection_reason" placeholder="Enter rejection reason before rejecting the order." invisible="state not in ('to approve', 'cancel')"/>
                        <button name="button_approve" type="object" string="Approve Order" class="oe_highlight" invisible="state != 'to approve'"/>
                        <button name="button_reject" type="object" string="Reject" class="btn-secondary" invisible="state != 'to approve'"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="action_purchase_orders_to_approve_ptp" model="ir.actions.act_window">
            <field name="name">Đơn hàng chờ duyệt</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">list,form,kanban,activity</field>
            <field name="search_view_id" ref="purchase.view_purchase_order_filter"/>
            <field name="domain">[('state', '=', 'to approve')]</field>
            <field name="context">{'search_default_to_approve': 1}</field>
        </record>

        <menuitem id="menu_purchase_orders_to_approve_ptp"
            name="Đơn hàng chờ duyệt"
            parent="purchase.menu_procurement_management"
            action="action_purchase_orders_to_approve_ptp"
            sequence="25"
            groups="purchase_user_link.group_purchase_manager_ptp"/>
    </data>
</odoo>