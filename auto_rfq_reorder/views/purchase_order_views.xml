<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_purchase_order_form_inherit_auto_rfq" model="ir.ui.view">
        <field name="name">purchase.order.form.auto_rfq</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Banner tự động - đặt trước field name -->
            <xpath expr="//field[@name='name']" position="before">
                <field name="is_auto_generated" invisible="1"/>
                <div role="status"
                     class="alert alert-warning mb-0"
                     invisible="not is_auto_generated">
                    Đơn này được <strong>tạo tự động</strong> bởi cơ chế tái đặt hàng.
                    Vui lòng xem xét kỹ trước khi gửi nhà cung cấp.
                </div>
            </xpath>

            <!-- Trường audit sau field origin -->
            <xpath expr="//field[@name='origin']" position="after">
                <field name="origin_trigger_custom"
                       string="Nguồn gốc tự động"
                       readonly="1"
                       invisible="not origin_trigger_custom"/>
            </xpath>

        </field>
    </record>

    <!-- Search View -->
    <record id="view_purchase_order_search_inherit_auto_rfq" model="ir.ui.view">
        <field name="name">purchase.order.search.auto_rfq</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter string="Đơn tạo tự động"
                        name="filter_auto_generated"
                        domain="[('is_auto_generated', '=', True)]"/>
            </xpath>
        </field>
    </record>

</odoo>