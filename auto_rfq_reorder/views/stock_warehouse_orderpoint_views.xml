<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_warehouse_orderpoint_form_inherit_auto_rfq" model="ir.ui.view">
        <field name="name">stock.warehouse.orderpoint.form.auto_rfq</field>
        <field name="model">stock.warehouse.orderpoint</field>
        <field name="inherit_id" ref="stock.view_warehouse_orderpoint_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="trigger_mode_custom" widget="radio" options="{'horizontal': true}" invisible="not active"/>
            </xpath>
        </field>
    </record>
</odoo>
